# ── LLM Provider ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LangSmith (optional but recommended for tracing) ─────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=CareerFlow

# ── Vector store ─────────────────────────────────────────────────────────────
# Directory where LlamaIndex persists its index
LLAMA_INDEX_STORAGE_DIR=./storage

# ── Backend server ────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
